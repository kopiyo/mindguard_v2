# ─────────────────────────────────────────────────────────────────────────────
# MindGuard — environment variables template
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────


# ─────────────────────────────────────────────
# Google OAuth — OPTION A (recommended)
# ─────────────────────────────────────────────
# Download the JSON file from Google Cloud Console:
#   APIs & Services → Credentials → OAuth 2.0 Client → Download JSON
# Place it anywhere in the project (it is gitignored) and set the path below.
# Never copy-paste the client secret manually — use the file instead.
#
# GOOGLE_CREDENTIALS_FILE=google_credentials.json


# ─────────────────────────────────────────────
# Google OAuth — OPTION B (env vars)
# ─────────────────────────────────────────────
# Use only if you cannot use the JSON file approach.
# Rotate secrets immediately if they are ever exposed.
#
# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_client_secret
# GOOGLE_REDIRECT_URI=http://localhost:8501

# Consent email delivery
# APP_BASE_URL=http://localhost:5173
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASSWORD=your_smtp_app_password


# ─────────────────────────────────────────────
# Cookie signing key (required)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ─────────────────────────────────────────────
SECRET_KEY=replace_with_output_of_secrets_token_hex_32

# Hugging Face trained Mental-RoBERTa weights
HF_REPO_ID=kopiyodiana/mindguard-mental-roberta
HF_TOKEN=
HF_WEIGHTS_FILE=mindguard_best_weights.pt
HF_TOKENIZER_SUBFOLDER=mindguard_tokenizer
HF_CACHE_DIR=.cache/huggingface


# ─────────────────────────────────────────────
# Optional: data source API keys
# ─────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
YOUTUBE_API_KEY=
